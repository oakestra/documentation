{
  "name": "documentation",
  "version": "1.8.0",
  "description": "Doks theme",
  "author": "Thulite",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oakestra"
  },
  "scripts": {
    "create": "hugo new",
    "dev": "hugo server --disableFastRender --noHTTPCache",
    "format": "prettier . --write --ignore-unknown",
    "build": "hugo --minify --gc",
    "serve": "http-server public -p 8000 -c-1 -g",
    "preview": "vite preview --outDir public",
    "update-oak-cli-docs": "bash ./auxiliary/oak_cli/update-oak-cli-docs.sh"
  },
  "dependencies": {
    "@tabler/icons": "^3.34.1",
    "@thulite/doks-core": "1.8.3",
    "@thulite/images": "^3.3.1",
    "@thulite/inline-svg": "^1.2.0",
    "@thulite/seo": "^2.4.1",
    "thulite": "2.5.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.5",
    "http-server": "^14.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-go-template": "^0.0.15",
    "vite": "^7.0.6"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
